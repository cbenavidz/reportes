# ==========================================================
# Configuración de conexión a Odoo 19 (Odoo.sh)
# ==========================================================
# Copia este archivo a .env y completa con tus datos reales.
# NO subas el archivo .env a Git ni lo compartas.

# URL de tu instancia de Odoo (sin / al final)
# Ej: https://casadelosmineros.odoo.com
ODOO_URL=https://tu-empresa.odoo.com

# Nombre de la base de datos (en Odoo.sh suele ser igual al subdominio)
ODOO_DB=tu-empresa

# Usuario API (correo del usuario)
ODOO_USERNAME=carlos@casadelosmineros.com.co

# API Key generada en Odoo: Preferencias > Cuenta > Claves API > Nueva API Key
# (NO uses tu contraseña personal)
ODOO_API_KEY=pega_aqui_tu_api_key

# ==========================================================
# Configuración de la aplicación
# ==========================================================

# Cuenta contable de cartera (Cuentas por Cobrar Comercial)
# En Colombia normalmente es 130505 o similar
CUENTA_CARTERA=1305

# Días para definir rangos de aging
AGING_RANGE_1=30
AGING_RANGE_2=60
AGING_RANGE_3=90

# Umbrales para scoring de clientes (días promedio de mora)
# A: excelente (mora <= UMBRAL_A)
# B: bueno (mora <= UMBRAL_B)
# C: regular (mora <= UMBRAL_C)
# D: malo (mora > UMBRAL_C)
UMBRAL_SCORING_A=5
UMBRAL_SCORING_B=15
UMBRAL_SCORING_C=30

# Caché local de datos (en minutos)
CACHE_TTL_MINUTES=15
