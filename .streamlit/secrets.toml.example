# =====================================================================
# PLANTILLA de secrets para Streamlit Cloud.
#
# ESTE archivo (.example) SÍ va al repo público — es solo la plantilla.
# El archivo real `.streamlit/secrets.toml` está en .gitignore y nunca
# se sube a Git.
#
# CÓMO USARLO EN STREAMLIT CLOUD:
#   1. Despliega la app desde tu repo de GitHub.
#   2. En la app, click en el menú "..." (esquina superior derecha)
#      → Settings → Secrets.
#   3. Pega el contenido de ESTE archivo, reemplazando los placeholders
#      con tus credenciales reales.
#   4. Save. Streamlit reinicia la app con los secrets cargados.
#
# CÓMO USARLO EN LOCAL (opcional, alternativa a .env):
#   Si prefieres, copia este archivo a `.streamlit/secrets.toml` y
#   completa con tus credenciales. Funciona igual que el `.env`.
# =====================================================================

# ---------------------------------------------------------------------
# Conexión a Odoo
# ---------------------------------------------------------------------
ODOO_URL = "https://tu-empresa.odoo.com"
ODOO_DB = "tu-empresa"
ODOO_USERNAME = "tu-correo@empresa.com"
# Genera tu API Key en Odoo: Preferencias → Cuenta → Claves API → Nueva
# (NO uses tu contraseña personal)
ODOO_API_KEY = "pega_aqui_tu_api_key"

# ---------------------------------------------------------------------
# Configuración del análisis (mismas claves que en .env.example)
# ---------------------------------------------------------------------
CUENTA_CARTERA = "1305"
AGING_RANGE_1 = "30"
AGING_RANGE_2 = "60"
AGING_RANGE_3 = "90"
UMBRAL_SCORING_A = "5"
UMBRAL_SCORING_B = "15"
UMBRAL_SCORING_C = "30"
CACHE_TTL_MINUTES = "15"

# Fecha desde la cual los datos de Odoo son confiables (formato YYYY-MM-DD).
# Antes de esta fecha, la app ignora movimientos para no contaminar
# rotación / DSO / hábito de pago con saldos iniciales del cargue.
DATA_FLOOR_DATE = "2025-09-01"

# ---------------------------------------------------------------------
# Usuarios autorizados a entrar a la app.
#
# El password_hash es SHA-256 del password. Para generarlo:
#   python3 -c "import hashlib; print(hashlib.sha256('TU_PASSWORD'.encode()).hexdigest())"
#
# Roles disponibles:
#   - admin    : acceso total
#   - cartera  : dashboard, aging, clientes, alertas, plan de cobro
#   - gerencia : solo lectura del dashboard ejecutivo
#
# Agrega un bloque [auth.users.NOMBRE] por cada usuario.
# ---------------------------------------------------------------------
[auth.users.carlos]
name = "Carlos Benavides"
email = "carlos@casadelosmineros.com.co"
role = "admin"
password_hash = "REEMPLAZAR_CON_HASH_SHA256_DE_TU_PASSWORD"

# Ejemplo de un segundo usuario (descomenta y ajusta):
# [auth.users.maria]
# name = "María Pérez"
# email = "maria@casadelosmineros.com.co"
# role = "cartera"
# password_hash = "..."
